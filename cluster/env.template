#!/bin/bash
# cluster/env.template — copy to cluster/<name>.env and edit
# All variables below are mandatory unless noted otherwise.

# --- Directories & Server ---
ZEP_BASE=/var/lib/zep-air          # base directory for all data (PKI, DB, storage, PID files)
SERVER_HOST=master.zep.lan         # server FQDN (must match server cert CN)
SERVER_PORT=8443

# --- PKI ---
CA_CN=Zep-CA                       # CA Common Name
CA_DAYS=3650
NODE_DAYS=365                      # validity of node/server/admin certs

# --- ZFS pools (space-separated) ---
ZFS_POOLS="za-master-pool za-client-1-pool za-client-2-pool"
ZFS_POOL_SIZE=256M                 # only used for loopback creation (--zfs flag)
# To skip ZFS pool creation: leave ZFS_POOLS empty

# --- Nodes (pairs of "cn:role:pool/dataset", space-separated) ---
# role must be 'master' or 'client'
NODES="za-master:master:za-master-pool/master \
       za-client-1:client:za-client-1-pool/slave \
       za-client-2:client:za-client-2-pool/slave"

# --- Cluster definition ---
CLUSTER_NAME=prod                  # cluster name
# Labels: name:minutes (retention = keep at most this many snapshots older than minutes)
CLUSTER_LABELS='{"hourly":60,"daily":1440,"weekly":10080}'
# Filesystem within the cluster pool (must match mapping `cluster_fs` part)
CLUSTER_FS=za-data-1
# Pool within the cluster definition (must match mapping `cluster_pool` part)
CLUSTER_POOL=za-pool-1

# --- Cron ---
CRON_INTERVAL=60                   # seconds between server polls (min 10)

# --- Server-side pipe_allow ---
PIPE_ALLOW="zfs,bash,cat,echo,head"
PIPE_ALLOW_TOOLS="buffer,mbuffer,zstd,lz4,gzip,gunzip"

# --- Optional: passphrase for encrypted PKI keys (leave empty for none) ---
KEY_PASSWORD=""

# --- Optional: run node commands as separate user accounts (1=yes) ---
# When set to 1, node DBs are chowned and commands run via sudo -u <cn>.
# Node user accounts (<cn>) must exist; created by cluster-init.sh --zfs.
SUDO_NODES=0
